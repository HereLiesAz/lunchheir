<?xml version="1.0" encoding="utf-8"?>
<!--
  Lunch Heir: override upstream Lawnchair's user-facing "Lawnchair" branding strings with "Lunch
  Heir". These are attached via the build-type res source sets in lunchheir-overlay.gradle, so they
  WIN over upstream's main res without a duplicate-resources clash (build types out-prioritise main).
  Names, placeholders, and translatable flags are kept identical to upstream — only the visible
  wording changes — so the strings still resolve everywhere upstream references them.
-->
<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="managed_by_lawnchair">Managed by Lunch Heir</string>
    <string name="accessibility_service_description">To perform certain actions (such as locking your phone) when performing a gesture, Lunch Heir requires accessibility access.\n\nLunch Heir doesn\'t watch any user action, though the privilege to do so is required for all accessibility services. Lunch Heir discards any event sent by the system.\n\nIn order to lock your phone, or to open the Recents screen, Lunch Heir uses the performGlobalAction Accessibility service.</string>
    <string name="onboarding_major_upgrade_title">Welcome to Lunch Heir <xliff:g example="16" id="next_major_version">%1$d</xliff:g>!</string>
    <string name="onboarding_welcome">Welcome to Lunch Heir!</string>
    <string name="set_default_launcher_tip">To access shortcuts and additional features, set Lunch Heir as your default launcher</string>
    <string name="debug_restart_launcher">Restart Lunch Heir</string>
    <string name="major_update_description">You are about to update from Lunch Heir <xliff:g example="15" id="current_major_version">%1$s</xliff:g> to Lunch Heir <xliff:g example="16" id="next_major_version">%2$s</xliff:g>, please consider carefully as newer major version may be unstable than current version.</string>
    <string name="lawnchair_bug_report">Lunch Heir bug report</string>
    <!-- Reworded (not a literal swap): upstream claims a Lawnchair revenue-share agreement, which is
         not Lunch Heir's — asserting it for Lunch Heir would be false (a Play-policy / legal risk).
         Drop the claim and just state the provider is sponsored. No "Lawnchair", no false statement. -->
    <string name="search_provider_sponsored_description">%1$s is a sponsored search provider.</string>
    <string name="hotseat_mode_lawnchair" translatable="false">Lunch Heir</string>
    <string name="smartspace_mode_lawnchair" translatable="false">Lunch Heir</string>
</resources>
